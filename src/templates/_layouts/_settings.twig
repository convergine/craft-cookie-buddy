{% extends '_layouts/cp' %}
{% set crumbs = [
    { label: "Settings"|t('app'), url: url('settings') },
] %}

{% set selectedSubnavItem = 'settings' %}

{% set navItems = {
    'settings-heading': { heading: "Settings"|t('convergine-cookiebuddy') },
    'general': { title: "General"|t('convergine-cookiebuddy') },
    'google': { title: "Google"|t('convergine-cookiebuddy') },
    'customization': { title: "Customization"|t('convergine-cookiebuddy') },
    'legal-heading': { heading: "Legal Policies"|t('convergine-cookiebuddy') },
    'privacy-policy': { title: "Privacy Policy"|t('convergine-cookiebuddy'), url: url('convergine-cookiebuddy/legal/privacy-policy') },
} %}

{# Active tab: all legal/* URLs map to the matching segment(3) key, except
   view/delete which map back to privacy-policy. #}
{% set seg2 = craft.app.request.getSegment(2) ?? 'settings' %}
{% set seg3 = craft.app.request.getSegment(3) ?? 'general' %}
{% set activeTab = (seg2 == 'legal') ? 'privacy-policy' : seg3 %}

{% block sidebar %}
    <nav>
        <ul>
            {% for key, element in navItems %}
                {% if element.heading is defined %}
                    <li class="heading">
                        <span>{{ element.heading }}</span>
                    </li>
                {% else %}
                    {% set href = element.url is defined ? element.url : url('convergine-cookiebuddy/settings/' ~ key) %}
                    <li>
                        <a href="{{ href }}" {{ activeTab == key ? 'class="sel"' }}>{{ element.title }}</a>
                    </li>
                {% endif %}
            {% endfor %}
        </ul>
    </nav>
{% endblock %}
